{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "mcp__plugin_playwright_playwright__*",
      "mcp__plugin_context7_context7__*",
      "mcp__plugin_serena_serena__*"
    ],
    "deny": [
      "Bash(npx prisma migrate reset*)",
      "Bash(npm run db:reset*)",
      "Bash(npx prisma db push --force-reset*)",
      "Bash(npx prisma db execute*)",
      "Bash(docker exec * psql * DROP*)",
      "Bash(docker exec * psql * TRUNCATE*)",
      "Bash(docker exec * psql * DELETE*)",
      "Bash(npm run db:prod:*)",
      "Bash(dotenv -e .env.production*)",
      "Bash(npx vercel *)",
      "Bash(npm publish*)"
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  }
}
